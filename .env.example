# ============================================
# PrendreUnRDV — Variables d'environnement
# ============================================
# Copiez ce fichier en .env et remplissez vos valeurs.
# ⚠️ Ne jamais committer le fichier .env avec des vraies clés !

# Appwrite Cloud — Endpoint de votre instance
VITE_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"

# Appwrite — ID du projet (visible dans la console Appwrite)
VITE_APPWRITE_PROJECT_ID="votre_project_id"

# Appwrite — ID de la base de données
VITE_APPWRITE_DB_ID="rdv_db"

# Appwrite — IDs des collections
VITE_APPWRITE_COLLECTION_USERS="users_collection"
VITE_APPWRITE_COLLECTION_APPOINTMENTS="appointments_collection"
VITE_APPWRITE_COLLECTION_CONFIG="config_collection"
VITE_APPWRITE_COLLECTION_AUDIT_LOGS="audit_logs_collection"
